pipeline {
    agent { label 'docker-agent' }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'SERVICE', defaultValue: 'vihire-backend', description: 'Service name from services.yml')
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch to build')
    }

    environment {
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-creds'
    }

    stages {
        stage('Load Service Metadata') {
            steps {
                script {
                    env.PLATFORM_DIR = fileExists('services.yml') ? '.' : 'platform-cicd'
                    def catalog = readYaml(file: "${env.PLATFORM_DIR}/services.yml")
                    def service = catalog.services.find { it.name == params.SERVICE }

                    if (service == null) {
                        error "Unknown SERVICE '${params.SERVICE}'. Check services.yml."
                    }

                    env.SERVICE_NAME = service.name
                    env.SERVICE_GIT_REPOSITORY = service.git_repository
                    env.DOCKER_IMAGE_NAME = service.docker_image_name
                    env.COMPOSE_FILE = service.compose_file
                    env.DEPLOY_TARGET = service.deploy_target
                    env.DEPLOY_PATH = service.deploy_path
                    env.HOST_PORT = service.host_port.toString()
                    env.CONTAINER_PORT = service.container_port.toString()
                }

                sh '''
                    set -eu
                    echo "Service: ${SERVICE_NAME}"
                    echo "Repository: ${SERVICE_GIT_REPOSITORY}"
                    echo "Image: ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                    echo "Compose template: ${COMPOSE_FILE}"
                    echo "Deploy target: ${DEPLOY_TARGET}"
                    echo "Deploy path: ${DEPLOY_PATH}"
                    echo "Platform directory: ${PLATFORM_DIR}"
                '''
            }
        }

        stage('Preflight Checks') {
            steps {
                sh '''
                    set -eu
                    echo "== Starting Preflight Checks =="
                    
                    echo "Checking Docker CLI and daemon access..."
                    docker info >/dev/null
                    
                    echo "Checking Docker socket..."
                    if [ ! -S /var/run/docker.sock ]; then
                        echo "Error: /var/run/docker.sock does not exist or is not a socket"
                        exit 1
                    fi
                    
                    echo "Checking reports directory creation..."
                    mkdir -p reports
                    touch reports/.preflight_test && rm reports/.preflight_test
                    
                    echo "Validating environment variables..."
                    if [ -z "${DOCKER_IMAGE_NAME:-}" ]; then
                        echo "Error: DOCKER_IMAGE_NAME is not set or empty"
                        exit 1
                    fi
                    if [ -z "${BUILD_NUMBER:-}" ]; then
                        echo "Error: BUILD_NUMBER is not set or empty"
                        exit 1
                    fi
                    echo "Preflight checks passed successfully!"
                '''
            }
        }

        stage('Clone Service Repository') {
            steps {
                dir('source') {
                    deleteDir()
                    git branch: params.BRANCH, url: env.SERVICE_GIT_REPOSITORY
                }

                sh '''
                    set -eu
                    cd source
                    echo "Branch: ${BRANCH}"
                    echo "Commit: $(git rev-parse --short HEAD)"
                '''
            }
        }

        stage('Semgrep SAST') {
            steps {
                sh '''
                    set +e
                    mkdir -p reports
                    echo "========================================"
                    echo "  Semgrep SAST Scan (Report-Only Phase 2)"
                    echo "========================================"

                    echo "Running Semgrep JSON output..."
                    docker run --rm \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      semgrep/semgrep \
                      semgrep scan --config auto --json -o reports/semgrep.json source/ || true

                    echo "Running Semgrep text output..."
                    docker run --rm \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      semgrep/semgrep \
                      semgrep scan --config auto source/ > reports/semgrep.txt 2>&1 || true

                    echo "Semgrep text result:"
                    cat reports/semgrep.txt

                    echo ""
                    echo "Semgrep SAST complete. Report-only mode — findings do NOT block pipeline in Phase 2."
                    echo "Reports: reports/semgrep.json , reports/semgrep.txt"
                '''
            }
        }

        stage('Semgrep Security Gate') {
            steps {
                sh '''
                    set +e
                    mkdir -p reports
                    echo "========================================"
                    echo "  Semgrep Security Gate (Phase 3B)"
                    echo "========================================"

                    GATE_RESULT="PASSED"
                    GATE_NOTES=""

                    if [ -f reports/semgrep.json ]; then
                        echo "Parsing Semgrep JSON for severity-based gating..."

                        python3 << 'PYEOF'
import json, sys

try:
    with open('reports/semgrep.json') as f:
        data = json.load(f)
except Exception as e:
    print(f"PARSE_ERROR: Could not parse semgrep.json: {e}")
    sys.exit(2)

results = data.get('results', [])
if not results:
    print("No Semgrep findings.")
    sys.exit(0)

blocking = []
for r in results:
    sev = r.get('extra', {}).get('severity', '').upper()
    cat = r.get('extra', {}).get('metadata', {}).get('category', '')
    scanner_cat = r.get('extra', {}).get('metadata', {}).get('scanner', {}).get('category', '')
    cwe = r.get('extra', {}).get('metadata', {}).get('cwe', [])
    check_id = r.get('check_id', 'unknown')
    path = r.get('path', 'unknown')
    line = r.get('start', {}).get('line', 0)

    is_security = ('security' in str(cat).lower() or 'security' in str(scanner_cat).lower())

    print(f"  [{sev:7s}] {check_id}  {path}:{line}")

    # Block only ERROR/CRITICAL security findings
    if sev in ('ERROR', 'CRITICAL') and is_security:
        blocking.append(f"  BLOCK: {check_id} at {path}:{line} ({sev})")

print()
if blocking:
    print("BLOCKING FINDINGS:")
    for b in blocking:
        print(b)
    sys.exit(1)
else:
    print("No blocking security findings.")
    sys.exit(0)
PYEOF
                        SEMGREP_EXIT=$?

                        if [ $SEMGREP_EXIT -eq 1 ]; then
                            echo "GATE: BLOCKED - Security-critical Semgrep findings detected" > reports/semgrep-gate.txt
                            echo "Status: BLOCKED" >> reports/semgrep-gate.txt
                            echo ""
                            echo "Semgrep Gate: FAILED - Security-critical findings found"
                            exit 1
                        elif [ $SEMGREP_EXIT -eq 2 ]; then
                            echo "GATE: REPORT-ONLY - Could not parse semgrep.json structure" > reports/semgrep-gate.txt
                            echo "Status: REPORT-ONLY (manual triage required)" >> reports/semgrep-gate.txt
                            echo "Note: Semgrep JSON did not have expected structure for automated gating." >> reports/semgrep-gate.txt
                            echo "Manual triage is required to verify no security-critical issues exist." >> reports/semgrep-gate.txt
                            echo ""
                            echo "Semgrep Gate: REPORT-ONLY - JSON parsing unreliable. See reports/semgrep-gate.txt"
                        else
                            echo "GATE: PASSED - No security-critical findings" > reports/semgrep-gate.txt
                            echo "Status: PASSED" >> reports/semgrep-gate.txt
                            echo ""
                            echo "Semgrep Gate: PASSED"
                        fi
                    else
                        echo "GATE: REPORT-ONLY - No semgrep.json found" > reports/semgrep-gate.txt
                        echo "Status: REPORT-ONLY (no Semgrep scan output available)" >> reports/semgrep-gate.txt
                        echo "Manual triage required to verify no security-critical issues exist." >> reports/semgrep-gate.txt
                        echo ""
                        echo "Semgrep Gate: REPORT-ONLY - No semgrep.json. See reports/semgrep-gate.txt"
                    fi
                '''
            }
        }

        stage('Dockerfile Lint') {
            steps {
                sh '''
                    set -eu
                    mkdir -p reports
                    echo "Running Hadolint on Dockerfile..."
                    docker run --rm -i hadolint/hadolint < source/Dockerfile > reports/hadolint.txt || true
                    echo "Hadolint Result:"
                    cat reports/hadolint.txt
                '''
            }
        }

        stage('Source Secret Scan') {
            steps {
                sh '''
                    set +e
                    mkdir -p reports
                    echo "========================================"
                    echo "  Source Secret Scan (Phase 3B)"
                    echo "========================================"

                    echo "Running Trivy filesystem secret scan on source/..."
                    docker run --rm \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      aquasec/trivy fs --security-checks secret --format json \
                      -o reports/source-secret-scan.json \
                      source/
                    TRIVY_SECRET_EXIT=$?

                    docker run --rm \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      aquasec/trivy fs --security-checks secret --format table \
                      -o reports/source-secret-scan.txt \
                      source/ || true

                    echo ""
                    echo "=== Safe Summary (no secret values exposed) ==="

                    python3 << 'PYEOF'
import json, sys

try:
    with open('reports/source-secret-scan.json') as f:
        data = json.load(f)
except Exception as e:
    print(f"PARSE_ERROR: {e}")
    sys.exit(2)

results = data.get('Results', [])
if not results:
    print("No secret or misconfig findings in source code.")
    sys.exit(0)

secret_count = 0
misconfig_critical = 0

for r in results:
    target = r.get('Target', 'unknown')
    cls = r.get('Class', '')

    if cls == 'secret':
        for s in r.get('Secrets', []):
            secret_count += 1
            rid = s.get('RuleID', 'unknown')
            sev = s.get('Severity', '?')
            cat = s.get('Category', '')
            # Show RuleID and severity only — NOT matched content
            print(f"  SECRET: {rid} [{sev}] in {target} ({cat})")
    elif cls == 'misconfig':
        for m in r.get('Misconfigurations', []):
            sev = m.get('Severity', '')
            if sev == 'CRITICAL':
                misconfig_critical += 1
                print(f"  MISCONFIG (CRITICAL): {m.get('ID','unknown')} in {target}")
            else:
                print(f"  MISCONFIG ({sev}): {m.get('ID','unknown')} in {target} — report-only")

print()
print(f"  Secrets found: {secret_count}")
print(f"  CRITICAL misconfigs: {misconfig_critical}")

if secret_count > 0 or misconfig_critical > 0:
    sys.exit(1)
sys.exit(0)
PYEOF
                    SCAN_EXIT=$?

                    if [ $SCAN_EXIT -eq 1 ]; then
                        echo "GATE: BLOCKED - Secrets or CRITICAL misconfigs found in source" > reports/source-secret-gate.txt
                        echo "Status: BLOCKED" >> reports/source-secret-gate.txt
                        python3 -c "
import json
with open('reports/source-secret-scan.json') as f:
    d = json.load(f)
s = sum(1 for r in d.get('Results',[]) for _ in r.get('Secrets',[]))
mc = sum(1 for r in d.get('Results',[]) for m in r.get('Misconfigurations',[]) if m.get('Severity')=='CRITICAL')
print(f'Secrets: {s}')
print(f'Critical misconfigs: {mc}')
" >> reports/source-secret-gate.txt
                        echo ""
                        echo "Source Secret Gate: BLOCKED - Failing pipeline before build"
                        exit 1
                    elif [ $SCAN_EXIT -eq 2 ]; then
                        echo "GATE: SKIPPED - JSON parse error" > reports/source-secret-gate.txt
                        echo "Status: SKIPPED (parse error)" >> reports/source-secret-gate.txt
                        echo ""
                        echo "Source Secret Gate: SKIPPED due to parse error"
                    else
                        echo "GATE: PASSED - No secrets or CRITICAL misconfigs in source" > reports/source-secret-gate.txt
                        echo "Status: PASSED" >> reports/source-secret-gate.txt
                        echo ""
                        echo "Source Secret Gate: PASSED"
                    fi
                '''
            }
        }

        stage('Build') {
            steps {
                sh '''
                    set -eu
                    docker build \
                      --pull \
                      --label "org.opencontainers.image.source=${SERVICE_GIT_REPOSITORY}" \
                      --label "org.opencontainers.image.revision=$(cd source && git rev-parse HEAD)" \
                      -t "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}" \
                      source
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    set -eu
                    mkdir -p reports /tmp/trivy-cache
                    TRIVY_CACHE="-v /tmp/trivy-cache:/root/.cache/trivy"
                    
                    echo "Running Trivy Scan (HIGH severity, report-only)..."
                    docker run --rm \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      ${TRIVY_CACHE} \
                      aquasec/trivy image --severity HIGH --format json \
                      -o reports/trivy-high.json "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}" || true
                    
                    docker run --rm \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      ${TRIVY_CACHE} \
                      aquasec/trivy image --severity HIGH --format table \
                      -o reports/trivy-high.txt "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}" || true
                    
                    echo "Running Trivy Scan (CRITICAL severity, report-only)..."
                    docker run --rm \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      ${TRIVY_CACHE} \
                      aquasec/trivy image --severity CRITICAL --format json \
                      -o reports/trivy-critical.json "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}" || true
                    
                    docker run --rm \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      ${TRIVY_CACHE} \
                      aquasec/trivy image --severity CRITICAL --format table \
                      -o reports/trivy-critical.txt "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}" || true

                    echo "Trivy Scan Results (CRITICAL):"
                    cat reports/trivy-critical.txt || true
                    
                    echo "Running Trivy Gate Check (CRITICAL severity, fails pipeline if findings exist)..."
                    docker run --rm \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      -v "$WORKSPACE":/workspace \
                      -w /workspace \
                      ${TRIVY_CACHE} \
                      aquasec/trivy image --severity CRITICAL --exit-code 1 --no-progress "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                '''
            }
        }

        stage('Push DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: env.DOCKERHUB_CREDENTIALS_ID,
                    usernameVariable: 'DOCKERHUB_USERNAME',
                    passwordVariable: 'DOCKERHUB_TOKEN'
                )]) {
                    sh '''
                        set -eu
                        printf '%s' "${DOCKERHUB_TOKEN}" | docker login -u "${DOCKERHUB_USERNAME}" --password-stdin
                        docker push "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                    '''
                }
            }
        }

        stage('Ansible Deploy') {
            steps {
                sh '''
                    set -eu
                    ansible-playbook -i "${PLATFORM_DIR}/inventory/hosts.yml" "${PLATFORM_DIR}/playbooks/deploy-service.yml" \
                      --limit "${DEPLOY_TARGET}" \
                      --extra-vars "service_name=${SERVICE_NAME}" \
                      --extra-vars "image_name=${DOCKER_IMAGE_NAME}" \
                      --extra-vars "image_tag=${BUILD_NUMBER}" \
                      --extra-vars "app_branch=${BRANCH}" \
                      --extra-vars "build_number=${BUILD_NUMBER}" \
                      --extra-vars "deploy_path=${DEPLOY_PATH}" \
                      --extra-vars "compose_template=${COMPOSE_FILE}" \
                      --extra-vars "host_port=${HOST_PORT}" \
                      --extra-vars "container_port=${CONTAINER_PORT}"
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    set -eu
                    mkdir -p reports
                    echo "Checking container user..."
                    docker exec ${SERVICE_NAME} id > reports/non-root-proof.txt
                    echo "Verification Result (non-root proof):"
                    cat reports/non-root-proof.txt
                '''
            }
        }

        stage('Phase 3A: Security Summary & Notification Skeleton') {
            steps {
                script {
                    env.BUILD_URL_CLEAN = env.BUILD_URL ?: "https://jenkins.example.com/job/${env.JOB_NAME}/${env.BUILD_NUMBER}/"
                }
                sh '''
                    set -eu
                    PLATFORM_DIR="${PLATFORM_DIR:-platform-cicd}"
                    bash "${PLATFORM_DIR}/scripts/security_notify.sh" \
                        "${JOB_NAME}" \
                        "${BUILD_NUMBER}" \
                        "${SERVICE_NAME}" \
                        "${BRANCH}" \
                        "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                    echo "Security summary and notification status generated."
                '''
            }
        }
    }

    post {
        always {
            sh 'docker logout || true'
            archiveArtifacts artifacts: 'reports/**', allowEmptyArchive: true
        }
    }
}
